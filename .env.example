# Copy to .env.local and fill in. Never commit .env.local.

# Firebase web config (public identifier — security comes from Firebase Rules)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Third-party APIs (real secrets — proxy through a backend in production)
VITE_SPOONACULAR_KEY=
VITE_RAPIDAPI_KEY=
VITE_RAPIDAPI_EXERCISEDB_HOST=exercisedb.p.rapidapi.com
